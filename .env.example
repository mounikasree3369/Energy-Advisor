# ============================================================
#  Smart Home Energy Advisor — Environment Configuration
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# IBM watsonx.ai Credentials
# Get from: https://cloud.ibm.com/iam/apikeys
# ----------------------------------------------------------
IBM_API_KEY=nrnU491jOkTehjtsA2c71NVNDXc91lM4qqCUIKd7SycU
# IBM Watson Machine Learning / watsonx.ai service URL
# Options:
#   us-south : https://us-south.ml.cloud.ibm.com
#   eu-de    : https://eu-de.ml.cloud.ibm.com
#   eu-gb    : https://eu-gb.ml.cloud.ibm.com
#   jp-tok   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM watsonx.ai Project ID
# Get from: https://dataplatform.cloud.ibm.com/projects
WATSONX_PROJECT_ID=df4e6479-e878-4da0-9bc2-5a96ecf73c9b
# IBM Granite Model ID (watsonx.ai)
# Recommended: ibm/granite-3-3-8b-instruct
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# ----------------------------------------------------------
# Flask Application Settings
# ----------------------------------------------------------
FLASK_SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ----------------------------------------------------------
# Application Settings
# ----------------------------------------------------------
# Local electricity rate in USD per kWh
ELECTRICITY_RATE_PER_KWH=8.0

# Carbon emission factor (kg CO2 per kWh) — US average
CARBON_FACTOR_KG_PER_KWH=0.386

# Timezone for peak/off-peak scheduling (pytz format)
APP_TIMEZONE=America/New_York

# Max tokens for AI responses
AI_MAX_TOKENS=1024

# AI response temperature (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.7
